ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# MySQL connection (optional — only needed if using MySQL source)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password-here
MYSQL_DATABASE=your-database-name-here

# Ollama (optional — only needed if using local Ollama models)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
